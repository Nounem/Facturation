<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata"><fullName>SiretFormat</fullName><active>true</active><errorConditionFormula>AND(NOT(ISBLANK(Siret__c)), NOT(REGEX(Siret__c, &quot;^[0-9]{14}$&quot;)))</errorConditionFormula><errorDisplayField>Siret__c</errorDisplayField><errorMessage>Le SIRET doit contenir exactement 14 chiffres.</errorMessage></ValidationRule>
